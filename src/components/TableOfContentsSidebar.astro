---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  tocHeadings.length > 0 && (
    <nav class="py-4">
      <p class="sidebar-label">// 目次</p>
      <ul class="list-none p-0 m-0 space-y-1">
        {tocHeadings.map((heading) => (
          <li class={heading.depth === 3 ? "ml-3" : ""}>
            <a
              href={`#${heading.slug}`}
              class="toc-link block text-sm leading-relaxed text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
