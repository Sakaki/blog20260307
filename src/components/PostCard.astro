---
import { formatDateJa } from "../utils/format-date";

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;
const formattedDate = formatDateJa(date);
---

<div class="group relative post-card">
  <a href={`/posts/${slug}`} class="absolute inset-0 z-10" aria-label={title}></a>
  <div>
    <h2
      class="text-base font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors"
    >
      <span class="text-[var(--accent)] opacity-70">{">"} </span>{title}
    </h2>
    <p class="text-xs text-[var(--text-secondary)] mt-1 date-terminal font-mono">
      {formattedDate}
    </p>
    <p class="text-sm text-[var(--text-secondary)] mt-2">{description}</p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3 relative z-20">
          {tags.map((tag) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag-chip">
              {tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</div>
