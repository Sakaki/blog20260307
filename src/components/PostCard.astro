---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;
const formattedDate = date.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div class="group relative card bg-base-100 border border-base-300 shadow-sm hover:shadow-md transition-shadow">
  <a href={`/posts/${slug}`} class="absolute inset-0 z-10" aria-label={title}></a>
  <div class="card-body">
    <h2 class="card-title text-base-content group-hover:text-primary transition-colors">
      {title}
    </h2>
    <p class="text-sm text-base-content/60">{formattedDate}</p>
    <p class="text-sm mt-1" style="color: color-mix(in oklch, var(--color-base-content) 70%, var(--color-base-100));">{description}</p>
    {
      tags.length > 0 && (
        <div class="card-actions mt-2 relative z-20">
          {tags.map((tag) => (
            <span class="badge badge-outline badge-sm">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</div>
