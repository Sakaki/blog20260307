---
import { getCollection } from "astro:content";
import { formatDateJaShort } from "../utils/format-date";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const recentPosts = allPosts
  .filter((post) => post.slug !== currentSlug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<section class="py-4 border-t border-[var(--border-color)]">
  <p class="sidebar-label">// 最近の記事</p>
  <ul class="list-none p-0 m-0 space-y-2">
    {
      recentPosts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}`} class="block group">
            <span class="text-sm leading-snug text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors line-clamp-2">
              {post.data.title}
            </span>
            <span class="text-xs text-[var(--text-secondary)] opacity-60">
              {formatDateJaShort(post.data.date)}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
