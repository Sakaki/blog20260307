---

---

<section class="bio-section">
  <!-- プロンプト行: sakaki@dev:~$ whoami -->
  <div class="bio-prompt">
    <span>
      <span class="ps1-host">sakaki</span><span class="ps1-sep">@</span><span class="ps1-host"
        >dev</span
      ><span class="ps1-sep">:~$</span>
    </span>
    <span class="ps1-cmd">whoami</span>
  </div>

  <!-- whoami 出力 -->
  <div class="bio-output">
    <div class="bio-row">
      <span class="bio-key">name</span>
      <span class="bio-colon">:</span>
      <span class="bio-val">Sakaki</span>
    </div>
    <div class="bio-row">
      <span class="bio-key">role</span>
      <span class="bio-colon">:</span>
      <span class="bio-val bio-val--role">
        <span class="role-tech">engineer</span>
        <span class="role-sep"> / </span>
        <span class="role-art">illustrator</span>
      </span>
    </div>
    <div class="bio-row bio-about">
      <span class="bio-key">about</span>
      <span class="bio-colon">:</span>
      <span class="bio-val bio-val--about">
        Twitterがイラスト投稿用アカウントに<br />
        なってしまったので、技術系の記事を<br />
        置いておく場所です。
      </span>
    </div>
  </div>

  <!-- tech リンクグループ -->
  <div class="bio-link-group">
    <div class="bio-group-label">// tech</div>
    <div class="bio-links">
      <a
        href="https://github.com/Sakaki"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--tech">GitHub</a
      >
      <a
        href="https://x.com/sakaki333"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--tech">X</a
      >
    </div>
  </div>

  <!-- creative リンクグループ -->
  <div class="bio-link-group">
    <div class="bio-group-label bio-group-label--art">// creative</div>
    <div class="bio-links">
      <a
        href="https://x.com/sakaki333"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--art">X (illust)</a
      >
      <a
        href="https://www.pixiv.net/users/52366365"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--art">Pixiv</a
      >
      <a
        href="https://sakaki333.fanbox.cc/"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--art">Fanbox</a
      >
      <a
        href="http://skeb.jp/@Sakaki333"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--art">Skeb</a
      >
      <a
        href="https://sakaki333.booth.pm/"
        target="_blank"
        rel="noopener noreferrer"
        class="bio-link bio-link--art">BOOTH</a
      >
    </div>
  </div>

  <!-- 末尾プロンプト（カーソル点滅） -->
  <div class="bio-prompt bio-prompt--tail">
    <span>
      <span class="ps1-host">sakaki</span><span class="ps1-sep">@</span><span class="ps1-host"
        >dev</span
      ><span class="ps1-sep">:~$</span>
    </span>
    <span class="bio-cursor"></span>
  </div>
</section>
