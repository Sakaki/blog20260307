---
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const tagMap = new Map<string, { displayName: string; count: number }>();

for (const post of allPosts) {
  for (const tag of post.data.tags) {
    const normalized = tag.toLowerCase();
    const existing = tagMap.get(normalized);
    if (existing) {
      existing.count++;
    } else {
      tagMap.set(normalized, { displayName: tag, count: 1 });
    }
  }
}

const tags = [...tagMap.entries()]
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([slug, { displayName }]) => ({ slug, displayName }));
---

<section class="py-4 border-t border-[var(--border-color)]">
  <p class="sidebar-label">// タグ</p>
  <div class="flex flex-wrap gap-1.5">
    {
      tags.map((tag) => (
        <a href={`/tags/${tag.slug}`} class="tag-chip">
          {tag.displayName}
        </a>
      ))
    }
  </div>
</section>
