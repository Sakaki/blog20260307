---
interface Props {
  pageTitle?: string;
}

const { pageTitle } = Astro.props;
---

<header
  id="site-header"
  class="navbar sticky top-0 z-50 bg-[var(--bg-primary)] border-b border-[var(--border-color)] transition-all duration-200"
  data-page-title={pageTitle ?? ""}
>
  <div class="navbar-start overflow-hidden">
    <a
      href="/"
      class="header-site-title btn btn-ghost text-lg font-mono font-bold text-[var(--accent)] transition-opacity duration-200"
    >
      ~/sakaki333.dev
    </a>
    <span
      class="header-page-title font-mono text-sm font-bold text-[var(--text-primary)] truncate opacity-0 absolute pointer-events-none transition-opacity duration-200"
    >
      {pageTitle}
    </span>
  </div>
  <div class="navbar-end">
    <!-- モバイル: ハンバーガーメニュー -->
    <div class="dropdown dropdown-end lg:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm text-[var(--text-secondary)]">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </div>
      <ul
        tabindex="0"
        class="dropdown-content menu bg-[var(--bg-secondary)] border border-[var(--border-color)] rounded z-10 w-40 p-2 shadow-lg"
      >
        <li>
          <a href="/" class="text-[var(--text-secondary)] hover:text-[var(--accent)]">Home</a>
        </li>
        <li>
          <a href="/posts" class="text-[var(--text-secondary)] hover:text-[var(--accent)]">Posts</a>
        </li>
        <li>
          <a href="/tags" class="text-[var(--text-secondary)] hover:text-[var(--accent)]">Tags</a>
        </li>
      </ul>
    </div>
    <!-- デスクトップ: インラインナビゲーション -->
    <nav class="hidden lg:flex gap-1">
      <a
        href="/"
        class="btn btn-ghost btn-sm text-[var(--text-secondary)] hover:text-[var(--accent)]"
      >
        Home
      </a>
      <a
        href="/posts"
        class="btn btn-ghost btn-sm text-[var(--text-secondary)] hover:text-[var(--accent)]"
      >
        Posts
      </a>
      <a
        href="/tags"
        class="btn btn-ghost btn-sm text-[var(--text-secondary)] hover:text-[var(--accent)]"
      >
        Tags
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const siteTitle = header.querySelector<HTMLElement>(".header-site-title");
    const pageTitle = header.querySelector<HTMLElement>(".header-page-title");
    const pageTitleText = header.dataset.pageTitle;
    const SCROLL_THRESHOLD = 80;

    let isCompact = false;

    function updateHeader(): void {
      const shouldBeCompact = window.scrollY > SCROLL_THRESHOLD;
      if (shouldBeCompact === isCompact) return;
      isCompact = shouldBeCompact;

      if (isCompact && pageTitleText) {
        header!.classList.add("header--compact");
        siteTitle!.classList.add("opacity-0", "pointer-events-none", "absolute");
        siteTitle!.classList.remove("opacity-100");
        pageTitle!.classList.remove("opacity-0", "pointer-events-none", "absolute");
        pageTitle!.classList.add("opacity-100");
      } else {
        header!.classList.remove("header--compact");
        siteTitle!.classList.remove("opacity-0", "pointer-events-none", "absolute");
        siteTitle!.classList.add("opacity-100");
        pageTitle!.classList.add("opacity-0", "pointer-events-none", "absolute");
        pageTitle!.classList.remove("opacity-100");
      }
    }

    window.addEventListener("scroll", updateHeader, { passive: true });
    updateHeader();
  }
</script>
