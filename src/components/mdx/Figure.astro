---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  sourceUrl?: string;
  sourceName?: string;
}

const { src, alt, caption, sourceUrl, sourceName } = Astro.props;
const displayCaption = caption ?? alt;
---

<figure class="my-6 flex flex-col items-center">
  <figcaption class="text-xs text-[var(--text-secondary)] mb-2 text-center">
    {displayCaption}
  </figcaption>
  <div class="figure-img-wrapper relative max-w-[80%] w-full">
    <div class="figure-skeleton skeleton h-48 w-full rounded"></div>
    <img
      src={src}
      alt={alt}
      class="figure-img rounded border border-[var(--border-color)] w-full opacity-0 transition-opacity duration-300"
      loading="lazy"
    />
  </div>
  {
    sourceUrl && sourceName && (
      <p class="text-xs text-[var(--text-secondary)] opacity-60 mt-1 italic">
        出典:{" "}
        <a href={sourceUrl} class="text-[var(--link-color)] hover:underline">
          {sourceName}
        </a>
      </p>
    )
  }
</figure>

<script>
  import { initFigures } from "./figure-loading";

  initFigures();
  document.addEventListener("astro:page-load", initFigures);
</script>
