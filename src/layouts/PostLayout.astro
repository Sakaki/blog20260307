---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import TableOfContentsSidebar from "../components/TableOfContentsSidebar.astro";
import SidebarRecentPosts from "../components/SidebarRecentPosts.astro";
import SidebarTags from "../components/SidebarTags.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import PostNavigation from "../components/PostNavigation.astro";
import { formatDateJa } from "../utils/format-date";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  frontmatter: {
    title: string;
    date: Date;
    tags: string[];
    description: string;
    heroImage?: string;
  };
  headings?: Heading[];
  readingTime?: number;
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
}

const { frontmatter, headings = [], readingTime, prevPost, nextPost } = Astro.props;
const { title, date, tags, description, heroImage } = frontmatter;
const formattedDate = formatDateJa(date);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 0;
const currentSlug = Astro.url.pathname.replace(/^\/posts\//, "").replace(/\/$/, "");
---

<BaseLayout
  title={title}
  description={description}
  maxWidth={hasToc ? "max-w-6xl" : "max-w-4xl"}
  pageTitle={title}
>
  <div class={hasToc ? "lg:grid lg:grid-cols-[1fr_16rem] lg:gap-8" : ""}>
    <article class="max-w-none">
      <header class="mb-8 border-b border-[var(--border-color)] pb-6">
        <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-3 page-title">
          {title}
        </h1>
        <p class="text-[var(--text-secondary)] text-sm mb-3 font-mono">
          <span class="date-terminal">{formattedDate}</span>
          {readingTime && <span class="ml-4 reading-time">{readingTime} min read</span>}
        </p>
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <a href={`/tags/${tag.toLowerCase()}`} class="tag-chip">
                  {tag}
                </a>
              ))}
            </div>
          )
        }
        {
          heroImage && (
            <div class="mt-6 flex justify-center">
              <img
                src={heroImage}
                alt={title}
                class="w-full rounded border border-[var(--border-color)]"
              />
            </div>
          )
        }
      </header>
      <div class="lg:hidden">
        <TableOfContents headings={headings} />
      </div>
      <div class="prose prose-base max-w-none">
        <slot />
      </div>
      <RelatedPosts currentSlug={currentSlug} currentTags={tags} />
      <PostNavigation prevPost={prevPost} nextPost={nextPost} />
    </article>
    {
      hasToc && (
        <aside class="hidden lg:block">
          <div class="sticky top-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
            <TableOfContentsSidebar headings={headings} />
            <SidebarRecentPosts currentSlug={currentSlug} />
            <SidebarTags />
          </div>
        </aside>
      )
    }
  </div>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
    if (tocLinks.length === 0) return;

    const headingIds = Array.from(tocLinks).map((link) =>
      link.getAttribute("href")?.replace("#", "")
    );

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove("active"));
            const activeLink = document.querySelector<HTMLAnchorElement>(
              `.toc-link[href="#${entry.target.id}"]`
            );
            activeLink?.classList.add("active");
          }
        }
      },
      { rootMargin: "-80px 0px -80% 0px" }
    );

    for (const id of headingIds) {
      if (id) {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
      }
    }
  });
</script>
