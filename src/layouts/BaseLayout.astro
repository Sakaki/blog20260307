---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { buildCanonicalUrl, buildOgImageUrl } from "../utils/seo";

interface Props {
  title: string;
  description?: string;
  maxWidth?: string;
  pageTitle?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  publishedTime?: string;
}

const {
  title,
  description,
  maxWidth = "max-w-4xl",
  pageTitle,
  ogType = "website",
  ogImage,
  publishedTime,
} = Astro.props;

const siteUrl = Astro.site?.href?.replace(/\/$/, "") ?? "https://sakaki333.dev";
const canonicalUrl = buildCanonicalUrl(Astro.url.pathname, siteUrl);
const resolvedOgImage = buildOgImageUrl(ogImage, siteUrl);
---

<!doctype html>
<html lang="ja" data-theme="terminal">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {description && <meta name="description" content={description} />}
    <link rel="alternate" type="application/rss+xml" title="sakaki333.dev" href="/rss.xml" />
    <meta property="og:title" content={title} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="sakaki333.dev" />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={resolvedOgImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:site" content="@sakaki333" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content font-mono">
    <Header pageTitle={pageTitle} />
    <main class={`flex-1 container mx-auto px-4 py-8 ${maxWidth}`}>
      <slot />
    </main>
    <Footer />
    <!-- トップに戻るボタン -->
    <button id="back-to-top" class="back-to-top" aria-label="ページトップに戻る">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"
        ></path>
      </svg>
    </button>
    <script>
      const backToTop = document.getElementById("back-to-top");
      if (backToTop) {
        const SHOW_THRESHOLD = 300;
        let isVisible = false;

        function updateBackToTop(): void {
          const shouldShow = window.scrollY > SHOW_THRESHOLD;
          if (shouldShow === isVisible) return;
          isVisible = shouldShow;
          backToTop!.classList.toggle("back-to-top--visible", isVisible);
        }

        window.addEventListener("scroll", updateBackToTop, { passive: true });
        updateBackToTop();

        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>
